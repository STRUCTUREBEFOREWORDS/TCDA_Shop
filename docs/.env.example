# TCDA — 環境変数テンプレート
# このファイルを .env にコピーして実際のキーを設定すること
# .env は .gitignore 済み — 絶対にコミットしないこと

# ─── Stripe ──────────────────────────────────────────────────────────────────
# テストキー: Stripe ダッシュボード → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook シークレット: Stripe ダッシュボード → Developers → Webhooks → エンドポイント追加後に取得
# ローカルテスト用: stripe listen --forward-to localhost:3000/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Printful ────────────────────────────────────────────────────────────────
# Printful ダッシュボード → Settings → API → Generate token
PRINTFUL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── サーバー設定 ─────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# 本番環境では以下に変更:
# BASE_URL=https://tcdashop.com
# NODE_ENV=production

NODE_ENV=development
