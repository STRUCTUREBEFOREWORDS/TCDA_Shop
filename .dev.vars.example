# Cloudflare Pages / Wrangler ローカル開発用シークレットテンプレート
# このファイルを .dev.vars にコピーして実際のキーを設定すること
# .dev.vars は .gitignore 済み — 絶対にコミットしないこと
#
# 使い方: npx wrangler pages dev .
# 本番環境: Cloudflare Pages → Settings → Environment variables に設定

# Stripe テストキー（Stripe ダッシュボード → Developers → API keys）
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook シークレット（ローカルは: stripe listen --forward-to localhost:8788/api/stripe/webhook）
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Printful API キー（Printful ダッシュボード → Settings → API → Generate token）
PRINTFUL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Printful ストア ID（Printful ダッシュボード → Stores → ストアID を確認）
PRINTFUL_STORE_ID=your_store_id_here
